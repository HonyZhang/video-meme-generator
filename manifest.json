{
  "manifest_version": 3,
  "name": "Video Meme Generator",
  "version": "1.0.0",
  "description": "Capture and turn video moments into memes!",
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": "public/icon.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads",
    "clipboardWrite"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content-script.js"]
    }
  ],
  "icons": {
    "128": "public/icon.png"
  }
} 